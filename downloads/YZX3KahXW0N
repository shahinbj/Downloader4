  <script>
    const videoData = {
      encId: "YZX3KahXW0N",
      filename: "YZX3KahXW0N.mp4",
      originalFilename: "YZX3KahXW0N.mp4",
      pageUrl: "https://turbo.cr/d/YZX3KahXW0N"
    };

    const fileSizeBytes = document.getElementById("fileSizeBytes");
    if (fileSizeBytes) {
      fileSizeBytes.textContent = parseInt(fileSizeBytes.textContent).toLocaleString();
    }

    function enableDownloadButtons(signedUrl) {
      const downloadBtn = document.getElementById("downloadBtn");
      const downloadBtnTop = document.getElementById("downloadBtnTop");
      const statusDot = document.getElementById("statusDot");
      const statusText = document.getElementById("statusText");

      if (downloadBtn && signedUrl) {
        downloadBtn.href = signedUrl;
        downloadBtn.classList.remove("bg-neutral-700", "pointer-events-none", "opacity-50");
        downloadBtn.classList.add("bg-red-700", "hover:bg-red-600");
      }
      if (downloadBtnTop && signedUrl) {
        downloadBtnTop.href = signedUrl;
        downloadBtnTop.classList.remove("bg-neutral-700", "pointer-events-none", "opacity-50");
        downloadBtnTop.classList.add("bg-red-700", "hover:bg-red-600");
      }
      if (statusDot) {
        statusDot.classList.remove("bg-amber-400");
        statusDot.classList.add("bg-emerald-400");
      }
      if (statusText) {
        statusText.textContent = "Ready";
      }
    }

    async function fetchSignedUrlAndEnable() {
      const statusText = document.getElementById("statusText");
      if (statusText) statusText.textContent = "Getting download link...";

      try {
        const response = await fetch('/api/sign?v=' + videoData.encId);
        const data = await response.json();
        if (data.success && data.url) {
          
          enableDownloadButtons(data.url + '&dl=1');
        } else {
          if (statusText) statusText.textContent = "Failed to get download link";
        }
      } catch (err) {
        console.error('Failed to get signed URL:', err);
        if (statusText) statusText.textContent = "Failed to get download link";
      }
    }

    document.addEventListener('DOMContentLoaded', () => {
      const captchaVerified = false;

      if (captchaVerified) {
        
        fetchSignedUrlAndEnable();
      } else {
        const altchaWidget = document.getElementById('altchaWidget');
        if (altchaWidget) {
          altchaWidget.addEventListener('statechange', (e) => {
            if (e.detail && e.detail.state === 'verified') {
              
              fetch('/api/captcha-verified', { method: 'POST' })
                .catch(err => console.log('Cookie set failed:', err));
              fetchSignedUrlAndEnable();
            }
          });
        }
      }
    });

    const toast = document.getElementById("toast");
    const toastText = document.getElementById("toastText");
    let toastTimer;

    function showToast(msg) {
      if (!toast || !toastText) return;
      toastText.textContent = msg;
      toast.classList.remove("hidden");
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => toast.classList.add("hidden"), 1400);
    }

    async function copyText(text) {
      try {
        await navigator.clipboard.writeText(text);
        showToast("Copied link");
      } catch {
        const ta = document.createElement("textarea");
        ta.value = text;
        ta.style.position = "fixed";
        ta.style.left = "-9999px";
        document.body.appendChild(ta);
        ta.select();
        document.execCommand("copy");
        document.body.removeChild(ta);
        showToast("Copied link");
      }
    }

    document.getElementById("copyBtn")?.addEventListener("click", () => copyText(videoData.pageUrl));
    document.getElementById("copyLinkBtn")?.addEventListener("click", () => copyText(videoData.pageUrl));
  </script>
  

